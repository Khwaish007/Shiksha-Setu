# Backend API URL (no trailing slash)
# Local development:
# VITE_API_BASE_URL=http://localhost:5000
#
# Production (set this in Vercel Environment Variables):
VITE_API_BASE_URL=https://your-backend-app.vercel.app

# Files per upload batch (default 2 — balances speed vs Vercel 4.5 MB limit)
# VITE_UPLOAD_BATCH_SIZE=2
