# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Anthropic API key for AI grading
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Frontend URL for CORS (set after deploying frontend)
FRONTEND_URL=https://your-frontend-app.vercel.app

# Optional: batch grading tuning
# UPLOAD_BATCH_SIZE — max files accepted per HTTP request by multer (default: 10)
UPLOAD_BATCH_SIZE=10
# CLAUDE_BATCH_SIZE — how many files are sent to Claude in parallel within one request (default: 5; keep low to avoid 429 rate limits)
CLAUDE_BATCH_SIZE=2
# CLAUDE_BATCH_DELAY_MS — delay in ms between Claude parallel sub-batches to prevent rate limiting (default: 1000)
CLAUDE_BATCH_DELAY_MS=1000
